# VitaFleet Checkout Service Configuration

# Server Configuration
PORT=3000
NODE_ENV=development

# Stripe API Configuration
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_test_... # Replace with your test/live API key
STRIPE_WEBHOOK_SECRET=whsec_... # Replace with your webhook signing secret

# Optional: Stripe account ID for multi-account support
# STRIPE_ACCOUNT_ID=acct_xxx...

# Database Configuration (if implemented)
# DATABASE_URL=postgresql://user:password@localhost:5432/vitafleet_checkout
# DATABASE_POOL_SIZE=10

# Logging Configuration
# LOG_LEVEL=info
# LOG_FORMAT=json

# Feature Flags
# ENABLE_3D_SECURE=true
# ENABLE_PAYMENT_RETRY=true
